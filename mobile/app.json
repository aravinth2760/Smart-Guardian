{
  "expo": {
    "name": "Smart Guardian",
    "slug": "smart-guardian",
    "version": "1.0.0",
    "orientation": "default",
    "scheme": "smartguardian",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.aravinth-user.smart-guardian"
    },
    "android": {
      "predictiveBackGestureEnabled": false,
      "package": "com.aravinthuser.smartguardian"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
