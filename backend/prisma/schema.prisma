generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Family {
  id String @id @default(cuid())

  name String

  familyCode String @unique

  users User[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

enum Relationship {
  father
  mother
  son
  daughter
  grandfather
  grandmother
  guardian
  other
}

enum Permission {
  owner
  manager
  member
}

enum ChatType {
  private
  group
}

model User {
  id String @id @default(cuid())

  phone String @unique

  name String?

  email String? @unique

  relationship Relationship?

  role Permission @default(member)

  profileCompleted Boolean @default(false)

  familyId String?

  family Family? @relation(fields: [familyId], references: [id], onDelete: SetNull)

  refreshToken RefreshToken?

  // Chat Relations
  createdChats Chat[] @relation("CreatedChats")

  chatMembers ChatMember[]

  sentMessages Message[] @relation("SentMessages")

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([familyId])
}

model RefreshToken {
  id String @id @default(cuid())

  tokenHash String @unique

  userId String @unique

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime

  revokedAt DateTime?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model Chat {
  id String @id @default(cuid())

  type ChatType

  // Group chat name
  name String?

  // Only for private chat
  privateKey String? @unique

  createdById String

  createdBy User @relation("CreatedChats", fields: [createdById], references: [id], onDelete: Cascade)

  members ChatMember[]

  messages Message[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([createdById])
}

model ChatMember {
  id String @id @default(cuid())

  chatId String

  userId String

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now())

  @@unique([chatId, userId])
  @@index([chatId])
  @@index([userId])
}

model Message {
  id String @id @default(cuid())

  chatId String

  senderId String

  text String

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  sender User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([chatId])
  @@index([senderId])
}
