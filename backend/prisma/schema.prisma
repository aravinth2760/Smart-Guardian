generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Relationship {
  father
  mother
  son
  daughter
  grandfather
  grandmother
  guardian
  other
}

enum Permission {
  owner
  manager
  member
}

enum ChatType {
  private
  group
}

enum ChatMemberRole {
  owner
  member
}

enum JoinRequestStatus {
  pending
  approved
  rejected
}

model User {
  id String @id @default(cuid())

  phone String @unique

  name String?

  email String? @unique

  relationship Relationship?

  role Permission @default(member)

  profileCompleted Boolean @default(false)

  refreshToken RefreshToken?

  sosSettings SOSSettings?

  createdChats Chat[] @relation("CreatedChats")

  chatMembers ChatMember[]

  sentMessages Message[] @relation("SentMessages")

  joinRequests JoinRequest[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model RefreshToken {
  id String @id @default(cuid())

  tokenHash String @unique

  userId String @unique

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime

  revokedAt DateTime?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model Chat {
  id String @id @default(cuid())

  type ChatType

  name String @default("Safety Circle")

  privateKey String? @unique

  inviteCode String? @unique

  inviteEnabled Boolean @default(false)

  createdById String

  createdBy User @relation(name: "CreatedChats", fields: [createdById], references: [id], onDelete: Cascade)

  members ChatMember[]

  joinRequests JoinRequest[]

  messages Message[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([createdById])
}

model ChatMember {
  id String @id @default(cuid())

  chatId String

  userId String

  role ChatMemberRole @default(member)

  sosEnabled Boolean @default(true)

  lastReadAt DateTime @default(now())

  joinedAt DateTime @default(now())

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
  @@index([chatId])
  @@index([userId])
}

model JoinRequest {
  id String @id @default(cuid())

  chatId String

  userId String

  status JoinRequestStatus @default(pending)

  requestedAt DateTime @default(now())

  respondedAt DateTime?

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
  @@index([chatId])
  @@index([userId])
  @@index([status])
}

enum MessageStatus {
  sent
  delivered
  read
}

model Message {
  id String @id @default(cuid())

  chatId String

  senderId String

  text String

  status MessageStatus @default(sent)

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  sender User @relation(name: "SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([chatId])
  @@index([senderId])
}

model SOSSettings {
  id                   String   @id @default(cuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message              String   @db.Text
  countdown            Int      @default(5)
  liveLocation         Boolean  @default(true)
  liveLocationDuration Int      @default(30)
  autoCall             Boolean  @default(true)
  smsBackup            Boolean  @default(true)
  alertSound           Boolean  @default(false)
  silentSOS            Boolean  @default(false)
  flashlightBlink      Boolean  @default(false)
  vibration            Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([userId])
}
